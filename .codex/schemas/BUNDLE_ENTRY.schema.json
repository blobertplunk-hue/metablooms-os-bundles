{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "BUNDLE_ENTRY.schema.json",
  "title": "MetaBlooms OS Bundle Entry",
  "description": "Schema for a single entry in the bundle catalog",
  "type": "object",
  "required": ["filename", "category", "size_bytes", "lfs_tracked", "lifecycle_status"],
  "properties": {
    "filename": {
      "type": "string",
      "description": "Exact filename as it appears in os_bundles/"
    },
    "category": {
      "type": "string",
      "enum": [
        "os_bundle",
        "os_bundle_part",
        "chat_export",
        "chat_export_part",
        "driver",
        "utility",
        "educational",
        "non_project",
        "ship_bundle",
        "recovery",
        "uploader",
        "misc_archive"
      ],
      "description": "Classification per BOOT.md taxonomy"
    },
    "extension": {
      "type": "string",
      "description": "File extension including dot (e.g., .zip, .exe, .part001)"
    },
    "size_bytes": {
      "type": "integer",
      "minimum": 0,
      "description": "File size in bytes"
    },
    "lfs_tracked": {
      "type": "boolean",
      "description": "Whether this file's extension is covered by .gitattributes LFS rules"
    },
    "date_prefix": {
      "type": ["string", "null"],
      "pattern": "^[0-9]{4}-[0-9]{2}-[0-9]{2}$",
      "description": "Date prefix if present in filename (YYYY-MM-DD)"
    },
    "timestamp_iso": {
      "type": ["string", "null"],
      "description": "ISO 8601 timestamp extracted from filename if present"
    },
    "phase": {
      "type": ["string", "null"],
      "enum": ["P0", "P1", "P2", "P3", null],
      "description": "Development phase marker if present"
    },
    "version_qualifiers": {
      "type": "array",
      "items": { "type": "string" },
      "description": "List of version qualifiers (CANONICAL, PATCHED, LTS, etc.)"
    },
    "feature_chain": {
      "type": "array",
      "items": { "type": "string" },
      "description": "Feature chain components extracted from PLUS-separated segments"
    },
    "is_duplicate": {
      "type": "boolean",
      "description": "Whether this appears to be a duplicate (e.g., filename with (1) suffix)"
    },
    "part_number": {
      "type": ["integer", "null"],
      "description": "Part number for segmented archives"
    },
    "part_total": {
      "type": ["integer", "null"],
      "description": "Total parts in the segment group if known"
    },
    "segment_group": {
      "type": ["string", "null"],
      "description": "Group identifier for multi-part archives"
    },
    "lifecycle_status": {
      "type": "string",
      "enum": ["ACTIVE", "SUPERSEDED", "DEPRECATED", "FROZEN", "DUPLICATE", "ORPHANED"],
      "description": "Lifecycle status per BUNDLE_LIFECYCLE_v1.md"
    },
    "superseded_by": {
      "type": ["string", "null"],
      "description": "Filename of the bundle that supersedes this one (if SUPERSEDED)"
    },
    "notes": {
      "type": ["string", "null"],
      "description": "Any additional observations about this file"
    }
  }
}
